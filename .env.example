# --- Supabase project (Dashboard → Project Settings → API) ---
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_KEY=YOUR-ANON-PUBLIC-KEY

# --- Direct Postgres connection for Drizzle (Dashboard → Project Settings → Database) ---
# Use the "Transaction pooler" URI (port 6543) and append ?prepare=false,
# or the "Session pooler" URI (port 5432).
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres
